#cloud-config
# Bootstrap only (#18): this user_data carries the host's config (.env,
# deploy.env) and a fetcher. Everything structural -- compose.yaml with its
# image pins, the Caddyfile route list, the seed-restore script -- lives in
# the repo's stack/demo/ tree and is fetched at boot by
# /opt/argus/argus-update, so changing any of it is a merge plus an in-place
# update, not a public-host replacement (which also took a new IPv4 and
# discarded the origin cert in caddy_data). What remains here changes rarely
# and legitimately WITH the host: secrets, addresses, and the bootstrap
# itself.
package_update: true
packages:
  - docker.io
  - docker-compose-v2
  - curl
  # restore-seed.sh untars the tape's demo/ subtree; zstd is not in the base image.
  - zstd

write_files:
  # Single source of truth for this host's runtime config, rendered by
  # Terraform and read by each service via `env_file`. See README > Environment.
  - path: /opt/argus/.env
    permissions: "0600"
    content: |
      # --- argus-curator (server) -------------------------------------------
      # scan/thumb/upload paths resolve under the scan root; server-side
      # containment (argus-curator >=0.2.0, argus-halo#1). The export root is
      # deliberately left unset so /export refuses on this public host.
      ARGUS_CURATOR_SCAN_ROOT=${curator_scan_root}
      ARGUS_CURATOR_EXPORT_ROOT=${curator_export_root}
      # curate -> caption handoff target (compose DNS, server-to-server).
      ARGUS_LENS_URL=http://lens:8100

      # --- argus-lens (captioning) ------------------------------------------
      # No GPU on this box. lens 0.5.0 SHIPS the lineage-replay backend
      # (argus-lens#45) but it is not switched on: ARGUS_BACKEND stays
      # openai-compat, so captions come from an OpenAI-compatible vision
      # endpoint (default: Cerebras gemma-4-31b). Flip ARGUS_BACKEND to replay
      # once the CORTEX_* stores below are consumed.
      ARGUS_BACKEND=openai-compat
      ARGUS_OPENAI_COMPAT_BASE_URL=${lens_caption_base_url}
      ARGUS_OPENAI_COMPAT_MODEL=${lens_caption_model}
      ARGUS_OPENAI_COMPAT_API_KEY=${lens_caption_api_key}

      # --- argus-quarry (provenance gallery) --------------------------------
      # Read-only API: every route is a GET. QUARRY_HOME is the provenance pool
      # the tape seeds (#9), mounted :ro -- see the quarry service in
      # stack/demo/compose.yaml for the rollback rule.
      QUARRY_HOME=${quarry_home}

      # --- argus-forge (training configs) -----------------------------------
      # Renders dataset/config/train.sh from a curated export. Live training is
      # OFF: forge refuses POST /run with 403 unless ARGUS_FORGE_READONLY=0, so
      # the safe state is the default and we deliberately do not set the var --
      # there is no GPU here (argus-forge#16). POST /config still dry-runs.
      ARGUS_FORGE_EXPORT_ROOT=${forge_export_root}

      # --- argus-proof (evaluation replay) ----------------------------------
      # Replay mode: serves the precomputed EvalReports the tape seeds (#9) and
      # 403s every write and live GPU eval, including POST /run/stream. Unlike
      # forge this is NOT the default, so setting it is load-bearing
      # (argus-proof#45, released in 0.2.0 via argus-proof#49). GET /health
      # reports read_only so studio can hide the run action (argus-studio#59).
      # PROOF_HOME itself is read by compose (the mount target), not the service.
      PROOF_HOME=${proof_home}
      ARGUS_PROOF_READ_ONLY=1
      ARGUS_PROOF_REPORTS_DIR=${proof_home}/reports
      ARGUS_PROOF_EXPORTS_DIR=${proof_home}/exports
      ARGUS_PROOF_RUNS_DIR=${proof_home}/runs

      # --- cortex store contract (RESERVED, not yet consumed) ---------------
      # The stores exist on core, but lens/curator 0.x do not read CORTEX_* yet
      # (argus-lens#45). Wired now so replay + lineage capture land without
      # re-plumbing; inert until a consumer ships. See README > Environment.
      CORTEX_PG_URL=${cortex_pg_url}
      CORTEX_QDRANT_URL=${cortex_qdrant_url}
      CORTEX_S3_ENDPOINT=${cortex_s3_endpoint}
      CORTEX_S3_BUCKET=${cortex_s3_bucket}
      CORTEX_S3_ACCESS_KEY=${minio_access_key}
      CORTEX_S3_SECRET_KEY=${minio_secret_key}
      CORTEX_S3_REGION=us-east-1

  # Non-secret deploy knobs the fetched stack reads (apply.sh sources this
  # next to .env): the public domain for Caddy, the tape URL, and which stack
  # this host tracks. 0600 anyway -- tape_dump_url is a presigned URL while
  # it lives.
  - path: /opt/argus/deploy.env
    permissions: "0600"
    content: |
      STACK_TARBALL_URL=${stack_tarball_url}
      STACK_TIER=demo
      DOMAIN=${domain}
      TAPE_DUMP_URL=${tape_dump_url}

  # The fetch-and-apply step: pulls the repo tarball at the tracked ref,
  # swaps the tier's stack/ subtree into place, and runs its apply.sh.
  # Deliberately tiny and generic -- ALL tier logic lives in the fetched
  # apply.sh, so this file (which IS ForceNew) should almost never change.
  # Identical in both tiers' templates on purpose; only deploy.env differs.
  # Run it over SSH any time to converge the host on the current ref:
  #   ssh <host> /opt/argus/argus-update
  - path: /opt/argus/argus-update
    permissions: "0755"
    content: |
      #!/usr/bin/env bash
      set -euo pipefail
      # shellcheck source=/dev/null
      . /opt/argus/deploy.env

      tmp="$(mktemp -d)"
      trap 'rm -rf "$tmp"' EXIT
      echo "fetching stack ($STACK_TIER) from $STACK_TARBALL_URL"
      curl -fsSL --retry 3 --retry-all-errors --retry-delay 5 "$STACK_TARBALL_URL" \
        | tar -xz -C "$tmp"
      src="$(find "$tmp" -mindepth 3 -maxdepth 3 -type d -path "*/stack/$STACK_TIER" | head -1)"
      [ -n "$src" ] && [ -f "$src/apply.sh" ] || {
        echo "no stack/$STACK_TIER/apply.sh in the fetched tarball -- refusing to apply" >&2
        exit 1
      }
      # Swap atomically-ish: never leave /opt/argus/stack half-written, and
      # keep the previous tree one `mv` away.
      rm -rf /opt/argus/stack.new
      cp -a "$src" /opt/argus/stack.new
      chmod +x /opt/argus/stack.new/*.sh
      rm -rf /opt/argus/stack.old
      [ -d /opt/argus/stack ] && mv /opt/argus/stack /opt/argus/stack.old
      mv /opt/argus/stack.new /opt/argus/stack
      exec /opt/argus/stack/apply.sh

runcmd:
  - [systemctl, enable, --now, docker]
  - [/opt/argus/argus-update]
