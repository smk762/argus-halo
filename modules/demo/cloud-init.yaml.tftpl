#cloud-config
package_update: true
packages:
  - docker.io
  - docker-compose-v2
  - curl

write_files:
  # Single source of truth for this host's runtime config, rendered by
  # Terraform and read by each service via `env_file`. See README > Environment.
  - path: /opt/argus/.env
    permissions: "0600"
    content: |
      # --- argus-curator (server) -------------------------------------------
      # scan/thumb/upload paths resolve under the scan root; server-side
      # containment (argus-curator >=0.2.0, argus-halo#1). The export root is
      # deliberately left unset so /export refuses on this public host.
      ARGUS_CURATOR_SCAN_ROOT=${curator_scan_root}
      ARGUS_CURATOR_EXPORT_ROOT=${curator_export_root}
      # curate -> caption handoff target (compose DNS, server-to-server).
      ARGUS_LENS_URL=http://lens:8100

      # --- argus-lens (captioning) ------------------------------------------
      # No GPU on this box and lens 0.4.0 has no lineage-replay backend
      # (argus-lens#45), so caption through an OpenAI-compatible vision endpoint
      # (default: Cerebras gemma-4-31b). Switch to the replay backend when #45
      # lands and CORTEX_* below start being consumed.
      ARGUS_BACKEND=openai-compat
      ARGUS_OPENAI_COMPAT_BASE_URL=${lens_caption_base_url}
      ARGUS_OPENAI_COMPAT_MODEL=${lens_caption_model}
      ARGUS_OPENAI_COMPAT_API_KEY=${lens_caption_api_key}

      # --- argus-quarry (provenance gallery) --------------------------------
      # Read-only API: every route is a GET (/photos, /stats, /subjects, /thumb).
      # QUARRY_HOME is the provenance pool the tape seeds (#9); mounted read-only.
      QUARRY_HOME=${quarry_home}

      # --- argus-forge (training configs) -----------------------------------
      # Renders dataset/config/train.sh from a curated export. Live training is
      # OFF: forge refuses POST /run with 403 unless ARGUS_FORGE_READONLY=0, so
      # the safe state is the default and we deliberately do not set the var --
      # there is no GPU here (argus-forge#16). POST /config still dry-runs.
      ARGUS_FORGE_EXPORT_ROOT=${forge_export_root}

      # --- argus-proof (evaluation replay) ----------------------------------
      # Replay mode: serves the precomputed EvalReports the tape seeds (#9) and
      # 403s every write and live GPU eval, including POST /run/stream. Unlike
      # forge this is NOT the default, so setting it is load-bearing
      # (argus-proof#45, released in 0.2.0 via argus-proof#49). GET /health
      # reports read_only so studio can hide the run action (argus-studio#59).
      ARGUS_PROOF_READ_ONLY=1
      ARGUS_PROOF_REPORTS_DIR=${proof_reports_dir}
      ARGUS_PROOF_EXPORTS_DIR=${proof_exports_dir}
      ARGUS_PROOF_RUNS_DIR=${proof_runs_dir}

      # --- cortex store contract (RESERVED, not yet consumed) ---------------
      # The stores exist on core, but lens/curator 0.x do not read CORTEX_* yet
      # (argus-lens#45). Wired now so replay + lineage capture land without
      # re-plumbing; inert until a consumer ships. See README > Environment.
      CORTEX_PG_URL=${cortex_pg_url}
      CORTEX_QDRANT_URL=${cortex_qdrant_url}
      CORTEX_S3_ENDPOINT=${cortex_s3_endpoint}
      CORTEX_S3_BUCKET=${cortex_s3_bucket}
      CORTEX_S3_ACCESS_KEY=${minio_access_key}
      CORTEX_S3_SECRET_KEY=${minio_secret_key}
      CORTEX_S3_REGION=us-east-1

  - path: /opt/argus/Caddyfile
    content: |
      # Cloudflare proxies in front of this and the zone is pinned to Full
      # (strict) in dns.tf -- Caddy terminates real TLS at the origin.
      #
      # One origin, one namespace per service: `/api/<service>/*` is stripped by
      # handle_path before the request reaches the backend, so curator still sees
      # /scan/folder and needs no changes. Anything unclaimed falls through to the
      # frontend (argus-studio#56 makes those base URLs runtime-configurable).
      #
      # Why a namespace and not the bare endpoint names. Enumerating each backend's
      # endpoints here meant the list had to be rediscovered every time a service
      # grew one -- and since user_data is ForceNew, every such fix replaces the
      # public host (#18). It also does not scale to the full suite: proof serves
      # /reports, /models, /exports and /run/stream at ITS root, which collide with
      # the frontend's pages and near-collide with curator's /export (#8).
      #
      # The trade, stated plainly: this is a passthrough, not a whitelist. Every
      # endpoint a service exposes is now reachable under its prefix, including
      # ones added by a future image bump. That is consistent with how this demo
      # already assigns responsibility -- containment is curator's job, enforced
      # server-side under ARGUS_CURATOR_SCAN_ROOT, and the proxy was never the
      # boundary (README > Security) -- but it does mean a service's own gating is
      # now load-bearing rather than backed up by the route list.
      #
      # Caveat for anything added later: the prefix is STRIPPED, so a service that
      # emits absolute URLs must be told its mount point (FastAPI: root_path) or
      # its generated links 404 at the edge.
      #
      # These prefixes and the paths in waf.tf are checked against each other by
      # scripts/check-cloud-init.sh.
      ${domain} {
        # No service's admin surface is public. The namespaces are passthroughs,
        # so anything a service exposes under /admin is reachable the moment the
        # image ships it -- lens already has POST /admin/unload, which the old
        # per-endpoint routing never reached. It is a no-op on the openai-compat
        # backend, but it becomes a model-unload lever the moment lens runs a
        # local model (the replay backend, argus-lens#45). One rule that holds
        # for every tier, present and future, beats finding out per release.
        # Bare + subtree per service, NOT `admin*` -- a trailing glob would also
        # swallow /administrator, /adminfoo and any real route that merely starts
        # with "admin". This matches the /admin segment and nothing longer.
        @admin path /api/lens/admin /api/lens/admin/* /api/curator/admin /api/curator/admin/* /api/quarry/admin /api/quarry/admin/* /api/forge/admin /api/forge/admin/* /api/proof/admin /api/proof/admin/*
        handle @admin {
          respond "admin endpoints are not exposed on this host" 404
        }

        handle_path /api/lens/* {
          reverse_proxy lens:8100
        }

        handle_path /api/curator/* {
          # /upload is an unauthenticated multipart endpoint. Scan-root containment
          # bounds WHERE a write lands, not how big it is, and the edge rate limit
          # counts requests, not bytes -- so cap the body here, at the only place
          # that sees it before curator spools it to disk. Sized for the sample
          # images curator ingests; raise it if the corpus grows.
          request_body {
            max_size 32MB
          }
          reverse_proxy curator:8101
        }

        handle_path /api/quarry/* {
          reverse_proxy quarry:8102
        }

        handle_path /api/forge/* {
          reverse_proxy forge:8103
        }

        handle_path /api/proof/* {
          reverse_proxy proof:8104
        }

        handle {
          reverse_proxy frontend:3000
        }
      }

  - path: /opt/argus/compose.yaml
    permissions: "0600"
    content: |
      services:
        caddy:
          image: caddy:2
          restart: unless-stopped
          ports: ["80:80", "443:443"]
          volumes:
            - /opt/argus/Caddyfile:/etc/caddy/Caddyfile:ro
            - caddy_data:/data

        frontend:
          # argus-studio: the suite's Next.js frontend (formerly argus-vision-demo).
          # Stays :latest until studio publishes a release (argus-halo#2), then
          # pin like the others.
          #
          # No `environment:` here on purpose: studio's NEXT_PUBLIC_* are inlined
          # at BUILD time, so setting them at runtime is inert (argus-studio#56).
          # The published image must be built for this origin, or -- preferred --
          # made runtime-configurable / same-origin (it already sits behind Caddy
          # on one origin here). Tracked in argus-studio#56.
          image: ghcr.io/smk762/argus-studio:latest
          restart: unless-stopped

        lens:
          # No GPU on this box by design. Backend + endpoint come from .env,
          # currently ARGUS_BACKEND=openai-compat -> Cerebras.
          #
          # 0.5.0 SHIPS the lineage-replay backend (argus-lens#45) -- the intended
          # end state, a caption path that needs no live model. It is not switched
          # on yet: replay reads the CORTEX_* stores, which are still marked
          # RESERVED in .env (no consumer had shipped). Flipping ARGUS_BACKEND to
          # replay and un-reserving CORTEX_* is the follow-up; the image is bumped
          # now so that change is one line, not an image bump plus a backend swap.
          # Route surface is identical to 0.4.0 (verified), so this bump is inert.
          image: ghcr.io/smk762/argus-lens:0.5.0
          restart: unless-stopped
          env_file: /opt/argus/.env
          command: ["argus-lens", "serve", "--cors", "--port", "8100"]

        curator:
          # [server] only -- the gpu extra is for detectors/embeddings we don't run here.
          # Pinned to >=0.2.0: server-side scan/export path containment (argus-halo#1).
          # ARGUS_CURATOR_SCAN_ROOT (set in .env) is what arms that containment.
          #
          # MOVING THIS PIN IS A SECURITY CHANGE. Caddy routes /api/curator/* as a
          # passthrough, so curator's own gating IS the public boundary -- there is
          # no route whitelist behind it any more. The behaviour relied on was
          # verified against exactly this tag (#19): empty ARGUS_CURATOR_EXPORT_ROOT
          # refuses /export, scan/folders reject paths outside the mount root, and
          # mode=move is 403. Re-run those probes before bumping; a release that
          # relaxed any of them would widen the public surface with no diff here.
          # 0.2.0 -> 0.2.1 was re-probed on 2026-07-23 and is byte-identical on all
          # six checks, which is what the rule above is for.
          image: ghcr.io/smk762/argus-curator:0.2.1
          restart: unless-stopped
          env_file: /opt/argus/.env
          command: ["argus-curator", "serve", "--cors", "--port", "8101"]
          volumes:
            - /srv/argus/samples:${curator_scan_root}:ro

        # --- full-suite tiers (#7) -----------------------------------------
        # Reached only through Caddy's /api/<service>/* namespaces; no published
        # ports, same as curator/lens. All three are read-only or replay here --
        # the box has no GPU by design, and #10 fixed the posture at 2 x CX23.
        quarry:
          # Provenance gallery. 0.2.1 is the first tag whose IMAGE can serve --
          # 0.2.0 shipped without the [server] extra (argus-quarry#3), so do not
          # roll this back. Note quarry also has a /thumb: it does not collide
          # with curator's because each sits under its own namespace.
          #
          # Still 0.2.1: the read-only fix (argus-quarry#5) is merged but v0.2.2
          # failed to publish -- its own release smoke test polls /health, which now
          # 503s on an empty QUARRY_HOME (argus-quarry#10). Bump to 0.2.2+ and flip
          # the mount back to :ro once that ships.
          #
          # NOT :ro, unlike every other mount here, and not by preference.
          # quarry's store opens its SQLite DB read-write on every request --
          # ProvenanceStore.__init__ even mkdir()s the metadata dir first -- so a
          # read-only mount makes the whole "read-only provenance API" 500
          # (verified: EROFS on mkdir, then "unable to open database file" once
          # the dir exists, because SQLite needs the directory writable for its
          # journal). Tracked upstream in argus-quarry#5; revert to :ro when it
          # opens the DB in read-only mode.
          #
          # What that costs us: nothing reachable from the internet. Every quarry
          # route is a GET (/photos, /stats, /subjects, /thumb, /health) -- there
          # is no public write path -- and the mount is quarry's own data
          # directory, not the sample corpus curator serves.
          image: ghcr.io/smk762/argus-quarry:0.2.1
          restart: unless-stopped
          env_file: /opt/argus/.env
          volumes:
            - /srv/argus/quarry:${quarry_home}

        forge:
          # Config renderer. Training is refused by default (403) -- see .env.
          image: ghcr.io/smk762/argus-forge:0.1.1
          restart: unless-stopped
          env_file: /opt/argus/.env
          volumes:
            - /srv/argus/exports:${forge_export_root}:ro

        proof:
          # Evaluation replay. 0.2.0 is the first tag carrying read-only mode
          # (argus-proof#49); 0.1.0 exposed live GPU eval ungated, so this pin is
          # a security boundary -- do not roll it back. Ships without the [score]
          # stack (torch/insightface), which is what keeps it at ~170 MB (#10).
          image: ghcr.io/smk762/argus-proof:0.2.1
          restart: unless-stopped
          env_file: /opt/argus/.env
          volumes:
            - /srv/argus/proof:/srv/argus/proof:ro

        # Host metrics for the demo tier. Listens on :9100 across interfaces but
        # the public interface is default-deny inbound (no firewall rule opens
        # 9100), so only core's Prometheus reaches it over the private network.
        node-exporter:
          # Pinned like the stores: a container recreate should not silently
          # change the thing reporting on the host.
          image: prom/node-exporter:v1.12.1
          restart: unless-stopped
          network_mode: host
          pid: host
          command:
            - "--path.rootfs=/host"
            - "--web.listen-address=:9100"
          volumes: ["/:/host:ro,rslave"]

      volumes:
        caddy_data:

runcmd:
  # Create every mount source before compose starts. Docker would create a
  # missing bind source as a root-owned directory anyway, but doing it here keeps
  # the seed layout explicit and matches what the tape restores into (#9).
  - [mkdir, -p, /srv/argus/samples, /srv/argus/quarry, /srv/argus/exports,
     /srv/argus/proof/reports, /srv/argus/proof/exports, /srv/argus/proof/runs]
  - [systemctl, enable, --now, docker]
  - [docker, compose, -f, /opt/argus/compose.yaml, up, -d]
